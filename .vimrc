syntax on

set tabstop=4
set shiftwidth=4
set expandtab
set relativenumber
set ai
set number
set hlsearch
set noerrorbells
set smartindent
set ruler
set nowrap
set smartcase
set noswapfile
set incsearch

" Give more space for displaying messages.
set cmdheight=2
set colorcolumn=80

colorscheme default
highlight ColorColumn ctermbg=0 guibg=lightgrey
highlight Comment ctermfg=green
