#!/bin/sh


wall_dir=~/wall

if [[ -z $1 || $1 == "-w" ]]; then
	echo "Choosing a random wallpaper";
  wall="$(find "$wall_dir" -type f -name "*.jpg" -o -name "*.png" | shuf -n1)"
else
  wall="$1"; shift
fi

onlywal=false

while getopts "w" arg; do
  case $arg in
    w) onlywal=true;;
  esac
done

convert "$wall" ~/.local/share/bg.jpg
xwallpaper --zoom ~/.local/share/bg.jpg


echo $onlywal

if [ "$onlywal" = false ] ; then
	wal -c
	wal -i ~/.local/share/bg.jpg -n

	echo "Recompiling dwm and st ..."
	(cd ~/dwm && sudo make clean install > /dev/null && cd ~/st && sudo make clean install > /dev/null &&  cd ~/dmenu && sudo make clean install > /dev/null)
fi
